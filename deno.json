{
  "tasks": {
    "run": "deno run -WR src/main.ts",
    "test": "deno test --unstable-raw-imports --parallel src/",
    "test:e2e": "deno test -WRE --allow-run --parallel e2e/",
    "typecheck": "deno check . --unstable-raw-imports --unstable-tsgo",
    "build": "deno run -WRES -N=jsr.io --allow-ffi scripts/build.ts",
    "fix": "deno fmt && deno lint --fix"
  },
  "fmt": {
    "proseWrap": "preserve"
  },
  "nodeModulesDir": "none",
  "imports": {
    "@david/dax": "jsr:@david/dax@0.48.5",
    "@david/jsonc-morph": "jsr:@david/jsonc-morph@0.3.4",
    "@deno/rolldown-plugin": "jsr:@deno/rolldown-plugin@0.0.10",
    "@ryu/enogu": "jsr:@ryu/enogu@0.7.0",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/cli": "jsr:@std/cli@1.0.30",
    "@std/fs": "jsr:@std/fs@1.0.24",
    "@std/path": "jsr:@std/path@1.1.6",
    "@std/semver": "jsr:@std/semver@1.0.8",
    "@std/yaml": "jsr:@std/yaml@1.1.1",
    "@std/jsonc": "jsr:@std/jsonc@1.0.2",
    "@valibot/valibot": "jsr:@valibot/valibot@1.4.1",
    "arkregex": "npm:arkregex@0.0.5",
    "tsdown": "npm:tsdown@0.22.3"
  },
  "exclude": [
    "testdata/*"
  ],
  "minimumDependencyAge": "P3D"
}
